@page
@model Login_User.Pages.Dashboard.DashboardModel
@{
    Layout = null;
    var nome = Model.NomeUsuario; // Substituir por: Model.NomeUsuario
}
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Dashboard — Login User</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --deep: #060212;
                --card: rgba(18, 6, 40, 0.82);
                --card2: rgba(28, 10, 58, 0.7);
                --accent: #9d4edd;
                --accent2: #c77dff;
                --glow: #e0aaff;
                --text: #f0e6ff;
                --muted: #b09ac0;
                --border: rgba(157, 78, 221, 0.28);
                --success: #4ade80;
            }

            html, body {
                height: 100%;
                font-family: 'Outfit', sans-serif;
            }

            body {
                background-color: var(--deep);
                background-image: radial-gradient(ellipse 80% 70% at 10% 90%, rgba(106, 13, 173, 0.45) 0%, transparent 60%), radial-gradient(ellipse 60% 50% at 90% 10%, rgba(157, 78, 221, 0.3) 0%, transparent 55%), radial-gradient(ellipse 50% 40% at 50% 50%, rgba(72, 12, 168, 0.18) 0%, transparent 70%);
                min-height: 100vh;
                color: var(--text);
                position: relative;
                overflow-x: hidden;
            }

            /* Orbs */
            .orb {
                position: fixed;
                border-radius: 50%;
                filter: blur(100px);
                pointer-events: none;
                z-index: 0;
            }

            .orb-1 {
                width: 600px;
                height: 600px;
                background: radial-gradient(circle, rgba(100, 20, 200, 0.3), transparent 70%);
                top: -200px;
                left: -150px;
                animation: drift1 16s ease-in-out infinite alternate;
            }

            .orb-2 {
                width: 450px;
                height: 450px;
                background: radial-gradient(circle, rgba(180, 100, 255, 0.22), transparent 70%);
                bottom: -100px;
                right: -80px;
                animation: drift2 20s ease-in-out infinite alternate;
            }

            @@keyframes drift1 {
                to {
                    transform: translate(60px, 80px);
                }
            }

            @@keyframes drift2 {
                to {
                    transform: translate(-60px, -60px);
                }
            }

            /* Navbar */
            .nav {
                position: relative;
                z-index: 10;
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 20px 48px;
                border-bottom: 1px solid var(--border);
                background: rgba(6, 2, 18, 0.7);
                backdrop-filter: blur(12px);
            }

            .nav-brand {
                font-family: 'Cinzel', serif;
                font-size: 1.15rem;
                font-weight: 600;
                color: var(--text);
                display: flex;
                align-items: center;
                gap: 10px;
            }

                .nav-brand::before {
                    content: '';
                    width: 8px;
                    height: 8px;
                    border-radius: 50%;
                    background: var(--accent2);
                    box-shadow: 0 0 10px var(--accent2);
                }

            .nav-right {
                display: flex;
                align-items: center;
                gap: 16px;
            }

            .nav-avatar {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: linear-gradient(135deg, #7b2fbe, #c77dff);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 0.85rem;
                font-weight: 600;
                color: white;
                border: 2px solid rgba(199, 125, 255, 0.4);
            }

            .nav-name {
                font-size: 0.9rem;
                color: var(--muted);
            }

            .btn-logout {
                background: rgba(157, 78, 221, 0.12);
                border: 1px solid rgba(157, 78, 221, 0.25);
                border-radius: 10px;
                padding: 7px 16px;
                font-family: 'Outfit', sans-serif;
                font-size: 0.83rem;
                color: var(--muted);
                cursor: pointer;
                text-decoration: none;
                transition: all 0.2s;
            }

                .btn-logout:hover {
                    background: rgba(157, 78, 221, 0.22);
                    color: var(--text);
                    border-color: rgba(199, 125, 255, 0.4);
                }

            /* Content */
            .content {
                position: relative;
                z-index: 1;
                max-width: 960px;
                margin: 0 auto;
                padding: 56px 32px 80px;
            }

            /* Hero section */
            .hero {
                text-align: center;
                margin-bottom: 64px;
                animation: fadeUp 0.7s ease both;
            }

            .success-icon {
                width: 72px;
                height: 72px;
                margin: 0 auto 24px;
                border-radius: 50%;
                background: rgba(74, 222, 128, 0.12);
                border: 2px solid rgba(74, 222, 128, 0.35);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 30px;
                box-shadow: 0 0 30px rgba(74, 222, 128, 0.15);
                animation: pulse 3s ease-in-out infinite;
            }

            @@keyframes pulse {
                0%, 100% {
                    box-shadow: 0 0 30px rgba(74, 222, 128, 0.15);
                }

                50% {
                    box-shadow: 0 0 50px rgba(74, 222, 128, 0.3);
                }
            }

            .hero h1 {
                font-family: 'Cinzel', serif;
                font-size: clamp(2rem, 4vw, 3rem);
                font-weight: 600;
                color: var(--text);
                margin-bottom: 14px;
                line-height: 1.2;
            }

                .hero h1 span {
                    background: linear-gradient(135deg, var(--accent2), var(--glow));
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                    background-clip: text;
                }

            .hero p {
                font-size: 1.05rem;
                color: var(--muted);
                max-width: 420px;
                margin: 0 auto;
                line-height: 1.7;
            }

            /* Status badge */
            .status-badge {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: rgba(74, 222, 128, 0.1);
                border: 1px solid rgba(74, 222, 128, 0.25);
                border-radius: 100px;
                padding: 6px 18px;
                font-size: 0.82rem;
                color: var(--success);
                margin-bottom: 24px;
                letter-spacing: 0.5px;
            }

                .status-badge::before {
                    content: '';
                    width: 6px;
                    height: 6px;
                    border-radius: 50%;
                    background: var(--success);
                    box-shadow: 0 0 8px var(--success);
                    animation: blink 2s ease-in-out infinite;
                }

            @@keyframes blink {
                0%, 100% {
                    opacity: 1;
                }

                50% {
                    opacity: 0.3;
                }
            }

            /* Cards grid */
            .grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
                gap: 20px;
                margin-bottom: 32px;
            }

            .card {
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 20px;
                padding: 28px 28px;
                backdrop-filter: blur(16px);
                box-shadow: 0 20px 60px rgba(0,0,0,0.35), inset 0 1px 0 rgba(255,255,255,0.04);
                transition: transform 0.25s, box-shadow 0.25s, border-color 0.25s;
            }

                .card:hover {
                    transform: translateY(-4px);
                    box-shadow: 0 28px 80px rgba(0,0,0,0.45), 0 0 30px rgba(157, 78, 221, 0.12);
                    border-color: rgba(199, 125, 255, 0.4);
                }

            .card-icon {
                width: 44px;
                height: 44px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 20px;
                margin-bottom: 18px;
            }

            .icon-purple {
                background: rgba(157, 78, 221, 0.18);
                border: 1px solid rgba(157, 78, 221, 0.25);
            }

            .icon-blue {
                background: rgba(96, 165, 250, 0.15);
                border: 1px solid rgba(96, 165, 250, 0.2);
            }

            .icon-green {
                background: rgba(74, 222, 128, 0.12);
                border: 1px solid rgba(74, 222, 128, 0.2);
            }

            .card-title {
                font-size: 0.8rem;
                font-weight: 500;
                text-transform: uppercase;
                letter-spacing: 1px;
                color: var(--muted);
                margin-bottom: 8px;
            }

            .card-value {
                font-size: 1.9rem;
                font-weight: 600;
                color: var(--text);
                font-family: 'Cinzel', serif;
                margin-bottom: 4px;
            }

            .card-sub {
                font-size: 0.82rem;
                color: var(--muted);
            }

            .card-badge {
                display: inline-block;
                background: rgba(74, 222, 128, 0.12);
                color: var(--success);
                font-size: 0.75rem;
                padding: 2px 10px;
                border-radius: 100px;
                margin-top: 8px;
            }

            /* Profile card */
            .profile-card {
                background: var(--card2);
                border: 1px solid var(--border);
                border-radius: 20px;
                padding: 32px 36px;
                backdrop-filter: blur(16px);
                display: flex;
                align-items: center;
                gap: 28px;
                animation: fadeUp 0.7s ease 0.4s both;
            }

            .profile-avatar {
                width: 72px;
                height: 72px;
                border-radius: 50%;
                background: linear-gradient(135deg, #5b21b6, #9d4edd, #c77dff);
                display: flex;
                align-items: center;
                justify-content: center;
                font-family: 'Cinzel', serif;
                font-size: 1.6rem;
                font-weight: 600;
                color: white;
                flex-shrink: 0;
                border: 3px solid rgba(199, 125, 255, 0.35);
                box-shadow: 0 0 24px rgba(157, 78, 221, 0.25);
            }

            .profile-info h3 {
                font-size: 1.2rem;
                font-weight: 600;
                color: var(--text);
                margin-bottom: 4px;
            }

            .profile-info p {
                font-size: 0.9rem;
                color: var(--muted);
                margin-bottom: 10px;
            }

            .profile-tags {
                display: flex;
                gap: 8px;
            }

            .tag {
                background: rgba(157, 78, 221, 0.14);
                border: 1px solid rgba(157, 78, 221, 0.25);
                border-radius: 100px;
                padding: 3px 12px;
                font-size: 0.77rem;
                color: var(--accent2);
            }

            .card-anim-1 {
                animation: fadeUp 0.7s ease 0.1s both;
            }

            .card-anim-2 {
                animation: fadeUp 0.7s ease 0.2s both;
            }

            .card-anim-3 {
                animation: fadeUp 0.7s ease 0.3s both;
            }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(24px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@media (max-width: 640px) {
                .nav {
                    padding: 16px 20px;
                }

                .content {
                    padding: 36px 20px 60px;
                }

                .profile-card {
                    flex-direction: column;
                    text-align: center;
                }

                .profile-tags {
                    justify-content: center;
                }
            }
    </style>
</head>
<body>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>

    <nav class="nav">
        <div class="nav-brand">Login User</div>
        <div class="nav-right">
            <span class="nav-name">@nome</span>
            <div class="nav-avatar">@(nome.Length > 0 ? nome[0].ToString().ToUpper() : "U")</div>
            <a href="/Login" class="btn-logout">Sair</a>
        </div>
    </nav>

    <div class="content">
        <div class="hero">
            <div class="status-badge">Sessão ativa</div>
            <div class="success-icon">✓</div>
            <h1>Olá, <span>@nome</span>!</h1>
            <p>Login realizado com sucesso. Você está autenticado e pode usar o sistema.</p>
        </div>

        <div class="grid">
            <div class="card card-anim-1">
                <div class="card-icon icon-purple">◈</div>
                <div class="card-title">Status</div>
                <div class="card-value">Ativo</div>
                <div class="card-sub">Conta em pleno funcionamento</div>
                <span class="card-badge">✓ Verificado</span>
            </div>
            <div class="card card-anim-2">
                <div class="card-icon icon-blue">◷</div>
                <div class="card-title">Último acesso</div>
                <div class="card-value" style="font-size:1.3rem;">@DateTime.Now.ToString("dd/MM/yyyy")</div>
                <div class="card-sub">@DateTime.Now.ToString("HH:mm") — Agora mesmo</div>
            </div>
            <div class="card card-anim-3">
                <div class="card-icon icon-green">⬡</div>
                <div class="card-title">Segurança</div>
                <div class="card-value" style="font-size:1.3rem;">Alta</div>
                <div class="card-sub">Senha armazenada com hash seguro</div>
            </div>
        </div>

        <div class="profile-card">
            <div class="profile-avatar">@(nome.Length > 0 ? nome[0].ToString().ToUpper() : "U")</div>
            <div class="profile-info">
                <h3>@nome</h3>
                <p>Usuário autenticado com sucesso</p>
                <div class="profile-tags">
                    <span class="tag">Ativo</span>
                    <span class="tag">Cadastrado</span>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
