@page
@model Login_User.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Entrar — Login User</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
            *, *::before, *::after {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --deep: #060212;
                --void: #0d0520;
                --dusk: #1a0a38;
                --mid: #2d1466;
                --card: rgba(18, 6, 40, 0.88);
                --accent: #9d4edd;
                --accent2: #c77dff;
                --glow: #e0aaff;
                --text: #f0e6ff;
                --muted: #b09ac0;
                --border: rgba(157, 78, 221, 0.35);
                --input-bg: rgba(255,255,255,0.05);
            }

            html, body {
                height: 100%;
                font-family: 'Outfit', sans-serif;
            }

            body {
                background-color: var(--deep);
                background-image: radial-gradient(ellipse 80% 60% at 20% 80%, rgba(106, 13, 173, 0.55) 0%, transparent 60%), radial-gradient(ellipse 60% 50% at 80% 20%, rgba(157, 78, 221, 0.35) 0%, transparent 55%), radial-gradient(ellipse 40% 40% at 50% 50%, rgba(72, 12, 168, 0.25) 0%, transparent 70%);
                min-height: 100vh;
                display: flex;
                align-items: stretch;
                overflow: hidden;
                position: relative;
            }

                /* Floating orbs */
                body::before, body::after {
                    content: '';
                    position: absolute;
                    border-radius: 50%;
                    filter: blur(80px);
                    pointer-events: none;
                    z-index: 0;
                }

                body::before {
                    width: 420px;
                    height: 420px;
                    background: radial-gradient(circle, rgba(138, 43, 226, 0.4), transparent 70%);
                    top: -100px;
                    left: -80px;
                    animation: drift1 12s ease-in-out infinite alternate;
                }

                body::after {
                    width: 350px;
                    height: 350px;
                    background: radial-gradient(circle, rgba(180, 100, 255, 0.3), transparent 70%);
                    bottom: -80px;
                    right: 20%;
                    animation: drift2 15s ease-in-out infinite alternate;
                }

            @@keyframes drift1 {
                to {
                    transform: translate(30px, 40px);
                }
            }

            @@keyframes drift2 {
                to {
                    transform: translate(-40px, -30px);
                }
            }

            /* Abstract shapes */
            .shapes {
                position: absolute;
                inset: 0;
                z-index: 0;
                pointer-events: none;
                overflow: hidden;
            }

            .shape {
                position: absolute;
                border-radius: 50%;
                border: 1px solid rgba(180, 100, 255, 0.15);
            }

            .shape-1 {
                width: 600px;
                height: 600px;
                top: -200px;
                left: -150px;
            }

            .shape-2 {
                width: 400px;
                height: 400px;
                bottom: -150px;
                left: 100px;
                border-color: rgba(157,78,221,0.1);
            }

            .shape-3 {
                width: 200px;
                height: 200px;
                top: 30%;
                left: 25%;
                border-color: rgba(220,180,255,0.08);
            }

            /* Triangle accent */
            .triangle {
                position: absolute;
                top: 50%;
                left: 42%;
                transform: translateY(-50%);
                width: 0;
                height: 0;
                border-left: 18px solid transparent;
                border-right: 18px solid transparent;
                border-bottom: 34px solid rgba(180, 100, 255, 0.25);
                z-index: 1;
            }

                .triangle::after {
                    content: '';
                    position: absolute;
                    top: 10px;
                    left: -12px;
                    width: 0;
                    height: 0;
                    border-left: 12px solid transparent;
                    border-right: 12px solid transparent;
                    border-bottom: 22px solid rgba(220, 160, 255, 0.12);
                }

            /* Layout */
            .page {
                display: flex;
                width: 100%;
                min-height: 100vh;
                position: relative;
                z-index: 1;
            }

            /* Left panel */
            .left {
                flex: 1;
                display: flex;
                flex-direction: column;
                justify-content: center;
                padding: 60px 80px;
                position: relative;
            }

            .left-badge {
                display: inline-flex;
                align-items: center;
                gap: 8px;
                background: rgba(157, 78, 221, 0.18);
                border: 1px solid rgba(157, 78, 221, 0.3);
                border-radius: 100px;
                padding: 6px 18px;
                font-size: 12px;
                letter-spacing: 2px;
                text-transform: uppercase;
                color: var(--accent2);
                margin-bottom: 36px;
                width: fit-content;
                animation: fadeUp 0.6s ease both;
            }

                .left-badge::before {
                    content: '';
                    width: 6px;
                    height: 6px;
                    border-radius: 50%;
                    background: var(--accent2);
                    box-shadow: 0 0 8px var(--accent2);
                }

            .welcome-title {
                font-family: 'Cinzel', serif;
                font-size: clamp(2.4rem, 4vw, 3.6rem);
                font-weight: 600;
                color: var(--text);
                line-height: 1.15;
                margin-bottom: 20px;
                animation: fadeUp 0.7s ease 0.1s both;
            }

                .welcome-title span {
                    background: linear-gradient(135deg, var(--accent2), var(--glow));
                    -webkit-background-clip: text;
                    -webkit-text-fill-color: transparent;
                    background-clip: text;
                }

            .welcome-sub {
                font-size: 1.05rem;
                color: var(--muted);
                line-height: 1.7;
                max-width: 380px;
                animation: fadeUp 0.7s ease 0.2s both;
            }

            .left-dots {
                display: flex;
                gap: 10px;
                margin-top: 48px;
                animation: fadeUp 0.7s ease 0.3s both;
            }

            .dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                background: rgba(157,78,221,0.4);
            }

                .dot.active {
                    background: var(--accent2);
                    box-shadow: 0 0 10px var(--accent2);
                    width: 24px;
                    border-radius: 4px;
                }

            /* Right panel */
            .right {
                width: 480px;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 40px 50px;
            }

            .card {
                width: 100%;
                background: var(--card);
                border: 1px solid var(--border);
                border-radius: 24px;
                padding: 44px 40px;
                backdrop-filter: blur(20px);
                box-shadow: 0 30px 80px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.05);
                animation: slideIn 0.6s ease both;
            }

            .card-header {
                margin-bottom: 32px;
            }

            .card-title {
                font-family: 'Cinzel', serif;
                font-size: 1.6rem;
                font-weight: 600;
                color: var(--text);
                margin-bottom: 8px;
            }

            .card-sub {
                font-size: 0.9rem;
                color: var(--muted);
            }

            /* Form */
            .field {
                margin-bottom: 20px;
            }

                .field label {
                    display: block;
                    font-size: 0.82rem;
                    font-weight: 500;
                    letter-spacing: 0.5px;
                    color: var(--muted);
                    text-transform: uppercase;
                    margin-bottom: 8px;
                }

                .field input {
                    width: 100%;
                    background: var(--input-bg);
                    border: 1px solid var(--border);
                    border-radius: 12px;
                    padding: 13px 16px;
                    font-family: 'Outfit', sans-serif;
                    font-size: 0.95rem;
                    color: var(--text);
                    outline: none;
                    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
                }

                    .field input::placeholder {
                        color: rgba(176,154,192,0.5);
                    }

                    .field input:focus {
                        border-color: var(--accent);
                        background: rgba(157, 78, 221, 0.08);
                        box-shadow: 0 0 0 3px rgba(157, 78, 221, 0.15);
                    }

            .field-row {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 20px;
            }

            .remember {
                display: flex;
                align-items: center;
                gap: 8px;
                font-size: 0.85rem;
                color: var(--muted);
                cursor: pointer;
            }

                .remember input[type=checkbox] {
                    width: 16px;
                    height: 16px;
                    accent-color: var(--accent);
                    cursor: pointer;
                }

            .forgot {
                font-size: 0.85rem;
                color: var(--accent2);
                text-decoration: none;
                transition: color 0.2s;
            }

                .forgot:hover {
                    color: var(--glow);
                }

            .btn-primary {
                width: 100%;
                background: linear-gradient(135deg, #7b2fbe, #9d4edd, #c77dff);
                border: none;
                border-radius: 12px;
                padding: 14px;
                font-family: 'Outfit', sans-serif;
                font-size: 0.95rem;
                font-weight: 600;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: white;
                cursor: pointer;
                transition: opacity 0.2s, transform 0.15s, box-shadow 0.2s;
                box-shadow: 0 4px 24px rgba(157, 78, 221, 0.45);
                margin-bottom: 28px;
            }

                .btn-primary:hover {
                    opacity: 0.9;
                    transform: translateY(-1px);
                    box-shadow: 0 8px 32px rgba(157, 78, 221, 0.6);
                }

                .btn-primary:active {
                    transform: translateY(0);
                }

            .divider {
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 24px;
            }

                .divider::before, .divider::after {
                    content: '';
                    flex: 1;
                    height: 1px;
                    background: rgba(157, 78, 221, 0.2);
                }

                .divider span {
                    font-size: 0.8rem;
                    color: var(--muted);
                    white-space: nowrap;
                }

            .signup-link {
                text-align: center;
                font-size: 0.88rem;
                color: var(--muted);
            }

                .signup-link a {
                    color: var(--accent2);
                    text-decoration: none;
                    font-weight: 500;
                    transition: color 0.2s;
                }

                    .signup-link a:hover {
                        color: var(--glow);
                    }

            /* Validation */
            .text-danger {
                color: #f87171;
                font-size: 0.8rem;
                margin-top: 4px;
                display: block;
            }

            @@keyframes fadeUp {
                from {
                    opacity: 0;
                    transform: translateY(20px);
                }

                to {
                    opacity: 1;
                    transform: translateY(0);
                }
            }

            @@keyframes slideIn {
                from {
                    opacity: 0;
                    transform: translateX(30px);
                }

                to {
                    opacity: 1;
                    transform: translateX(0);
                }
            }

            @@media (max-width: 768px) {
                .left {
                    display: none;
                }

                .right {
                    width: 100%;
                    padding: 24px;
                }

                .card {
                    border-radius: 20px;
                    padding: 36px 28px;
                }
            }
    </style>
</head>
<body>
    <div class="shapes">
        <div class="shape shape-1"></div>
        <div class="shape shape-2"></div>
        <div class="shape shape-3"></div>
    </div>
    <div class="triangle"></div>

    <div class="page">
        <div class="left">
            <div class="left-badge">Sistema de acesso</div>
            <h1 class="welcome-title">
                Bem-vindo<br>de <span>volta</span>
            </h1>
            <p class="welcome-sub">
                Acesse sua conta e continue sua jornada. Estamos felizes em ter você aqui novamente.
            </p>
            <div class="left-dots">
                <div class="dot active"></div>
                <div class="dot"></div>
                <div class="dot"></div>
            </div>
        </div>

        <div class="right">
            <div class="card">
                <div class="card-header">
                    <h2 class="card-title">Entrar</h2>
                    <p class="card-sub">Insira suas credenciais para continuar</p>
                </div>

                <form method="post" asp-page="/Login">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom:16px;"></div>

                    <div class="field">
                        <label asp-for="Input.Email">E-mail</label>
                        <input asp-for="Input.Email" type="email" placeholder="voce@email.com" autocomplete="email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="field">
                        <label asp-for="Input.Senha">Senha</label>
                        <input asp-for="Input.Senha" type="password" placeholder="••••••••" autocomplete="current-password" />
                        <span asp-validation-for="Input.Senha" class="text-danger"></span>
                    </div>

                    <div class="field-row">
                        <label class="remember">
                            <input type="checkbox" name="lembrar" />
                            Lembrar de mim
                        </label>
                        <a href="#" class="forgot">Esqueceu a senha?</a>
                    </div>

                    <button type="submit" class="btn-primary">Entrar</button>
                </form>

                <div class="divider"><span>ou</span></div>

                <div class="signup-link">
                    Não tem conta? <a asp-page="/Auth/Register">Criar conta</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
